PORT=3003
NODE_ENV=development

# Redis (session state + stop pub/sub)
REDIS_URL=redis://localhost:6379

# AWS SQS
AWS_REGION=us-east-1
AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/mitsi-recording-queue
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Mitsi web frontend URL (the bot navigates here)
MITSI_WEB_URL=http://localhost:5173
MITSI_API_KEY=

# Recording
RECORDINGS_DIR=/tmp/mitsi-recordings
MAX_RECORDING_DURATION_MS=21600000
SQS_VISIBILITY_TIMEOUT=28800
SQS_POLL_WAIT_SECONDS=20
