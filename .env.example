PORT=3003
NODE_ENV=development

# Redis (session state)
REDIS_URL=redis://localhost:6379

# Mitsi web frontend URL (the bot navigates here to join the meeting)
MITSI_WEB_URL=http://localhost:5173
MITSI_API_KEY=

# Recording (defaults to <project-root>/recordings/ if not set)
# RECORDINGS_DIR=/custom/path/to/recordings
MAX_RECORDING_DURATION_MS=21600000
